# Generated by devenv-generator
# Profile: {{ profile.name }}
# {{ profile.description }}
FROM python:{{ profile.python.version }}-slim

ARG DEBIAN_FRONTEND=noninteractive

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
{% for pkg in profile.system_packages %}
    {{ pkg }} \
{% endfor %}
    nodejs \
    npm \
    && rm -rf /var/lib/apt/lists/*

{% if 'fd-find' in profile.system_packages %}
# Create symlink for fd (Debian names it fdfind)
RUN ln -s $(which fdfind) /usr/local/bin/fd
{% endif %}

{% if profile.github_releases %}
# Install tools from GitHub releases (multi-arch support)
{% for name, url in profile.github_releases.items() %}
{% if url.endswith('.deb') %}
RUN ARCH=$(dpkg --print-architecture) && \
    URL=$(echo "{{ url }}" | sed "s/amd64/$ARCH/g") && \
    curl -LO "$URL" && \
    dpkg -i "$(basename "$URL")" && \
    rm "$(basename "$URL")"
{% endif %}
{% endfor %}
{% endif %}

# Install uv (fast Python package manager)
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:$PATH"

{% if profile.uvx_tools %}
# Install Python dev tools globally via uv tool
RUN {% for tool in profile.uvx_tools %}uv tool install {{ tool }}{% if not loop.last %} \
    && {% endif %}{% endfor %}

{% endif %}

{% if profile.node_packages %}
# Install Node.js packages globally
RUN npm install -g {% for pkg in profile.node_packages %}{{ pkg }}{% if not loop.last %} {% endif %}{% endfor %}

{% endif %}

{% if 'delta' in profile.github_releases %}
# Configure git to use delta for diffs
RUN git config --global core.pager delta \
    && git config --global interactive.diffFilter "delta --color-only" \
    && git config --global delta.navigate true \
    && git config --global delta.light false \
    && git config --global delta.line-numbers true
{% endif %}

{% if 'zsh' in profile.system_packages %}
# Set up zsh as default shell
RUN chsh -s $(which zsh)
{% endif %}

# Create non-root user (Claude Code refuses to run as root)
# UID 501 matches default macOS user for proper file permissions on bind mounts
ARG USERNAME=developer
ARG USER_UID=501
ARG USER_GID=$USER_UID
RUN groupadd --gid $USER_GID $USERNAME \
    && useradd --uid $USER_UID --gid $USER_GID -m $USERNAME -s {% if 'zsh' in profile.system_packages %}/bin/zsh{% else %}/bin/bash{% endif %} \
    && mkdir -p /home/$USERNAME/.local/bin \
    && mkdir -p /home/$USERNAME/.claude \
    && mkdir -p /home/$USERNAME/.config/sops/age \
    && chown -R $USERNAME:$USERNAME /home/$USERNAME

# Pre-configure Claude Code to skip onboarding prompts
RUN echo '{"hasCompletedOnboarding":true,"theme":"dark"}' > /home/$USERNAME/.claude.json \
    && chown $USERNAME:$USERNAME /home/$USERNAME/.claude.json

# Pre-configure Claude Code settings with broad permissions (container is isolated)
RUN echo '{"permissions":{"allow":["Bash(*)","Read","Write","Edit","Glob","Grep","Task","WebFetch","WebSearch","NotebookEdit"]},"defaultMode":"bypassPermissions"}' > /home/$USERNAME/.claude/settings.json \
    && chown $USERNAME:$USERNAME /home/$USERNAME/.claude/settings.json

# Copy uv tools to user's path
RUN cp -r /root/.local/bin/* /home/$USERNAME/.local/bin/ \
    && chown -R $USERNAME:$USERNAME /home/$USERNAME/.local

# Create startup script that runs uv sync and then the command
RUN cat > /home/$USERNAME/.local/bin/devenv-start << 'SCRIPT'
#!/bin/sh
set -e

# Find the first workspace directory with pyproject.toml
for dir in /workspace/*; do
    if [ -d "$dir" ] && [ -f "$dir/pyproject.toml" ]; then
        cd "$dir"
        echo "Installing dependencies in $dir..."
        uv sync --quiet 2>/dev/null || true
        break
    fi
done

# If no command provided, start Claude in YOLO mode
if [ $# -eq 0 ]; then
    exec claude --dangerously-skip-permissions
else
    exec "$@"
fi
SCRIPT
RUN chmod +x /home/$USERNAME/.local/bin/devenv-start

# Switch to non-root user
USER $USERNAME

# Create workspace directory
WORKDIR /workspace

# Set environment variables
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV PATH="/home/developer/.local/bin:$PATH"
{% if 'zsh' in profile.system_packages %}
ENV SHELL=/bin/zsh
{% endif %}

# Use startup script as entrypoint
ENTRYPOINT ["devenv-start"]

# Default is to start Claude (handled by entrypoint when no args)
CMD []
