# Generated by devenv-generator
# Profile: {{ profile.name }}
# {{ profile.description }}
FROM python:{{ profile.python.version }}-slim

ARG DEBIAN_FRONTEND=noninteractive

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
{% for pkg in profile.system_packages %}
    {{ pkg }} \
{% endfor %}
{% if 'gnupg' in profile.system_packages %}
    socat \
{% endif %}
{% if profile.network.mode == 'restricted' %}
    iptables \
{% endif %}
    nodejs \
    npm \
    sudo \
    tini \
    && rm -rf /var/lib/apt/lists/*

{% if profile.playwright %}
# Install Playwright browser dependencies for Chromium/Firefox/WebKit
# Required for running browser-based tests (Playwright, Puppeteer, etc.)
RUN apt-get update && apt-get install -y --no-install-recommends \
    libglib2.0-0 \
    libnspr4 \
    libnss3 \
    libdbus-1-3 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libxcb1 \
    libxkbcommon0 \
    libatspi2.0-0 \
    libx11-6 \
    libxcomposite1 \
    libxdamage1 \
    libxext6 \
    libxfixes3 \
    libxrandr2 \
    libgbm1 \
    libcairo2 \
    libpango-1.0-0 \
    libasound2 \
    libxshmfence1 \
    libdrm2 \
    libxrender1 \
    fonts-liberation \
    && rm -rf /var/lib/apt/lists/*
{% endif %}

{% if 'fd-find' in profile.system_packages %}
# Create symlink for fd (Debian names it fdfind)
RUN ln -s $(which fdfind) /usr/local/bin/fd
{% endif %}

{% if profile.github_releases %}
# Install tools from GitHub releases (multi-arch support)
{% for name, url in profile.github_releases.items() %}
{% if url.endswith('.deb') %}
RUN ARCH=$(dpkg --print-architecture) && \
    URL=$(echo "{{ url }}" | sed "s/amd64/$ARCH/g") && \
    curl -LO "$URL" && \
    dpkg -i "$(basename "$URL")" && \
    rm "$(basename "$URL")"
{% endif %}
{% endfor %}
{% endif %}

# Install uv (fast Python package manager)
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:$PATH"

{% if profile.uvx_tools %}
# Install Python dev tools globally via uv tool
RUN {% for tool in profile.uvx_tools %}uv tool install {{ tool }}{% if not loop.last %} \
    && {% endif %}{% endfor %}

{% endif %}

{% if profile.node_packages %}
# Install Node.js packages globally
RUN npm install -g {% for pkg in profile.node_packages %}{{ pkg }}{% if not loop.last %} {% endif %}{% endfor %}

{% endif %}

{% if profile.playwright %}
# Install Playwright browsers (Chromium, Firefox, WebKit)
# System dependencies already installed above, just need browsers
RUN npx playwright install chromium firefox webkit
{% endif %}

{% if profile.docker_cli %}
# Install Docker CLI for Docker-in-Docker via socket mount
RUN apt-get update && apt-get install -y --no-install-recommends \
    apt-transport-https \
    ca-certificates \
    gnupg \
    lsb-release \
    && curl -fsSL https://download.docker.com/linux/debian/gpg | gpg --dearmor -o /usr/share/keyrings/docker-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/docker-archive-keyring.gpg] https://download.docker.com/linux/debian $(lsb_release -cs) stable" > /etc/apt/sources.list.d/docker.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends docker-ce-cli docker-compose-plugin \
    && rm -rf /var/lib/apt/lists/*
{% endif %}

{% if 'delta' in profile.github_releases %}
# Configure git to use delta for diffs
RUN git config --global core.pager delta \
    && git config --global interactive.diffFilter "delta --color-only" \
    && git config --global delta.navigate true \
    && git config --global delta.light false \
    && git config --global delta.line-numbers true
{% endif %}

{% if 'zsh' in profile.system_packages %}
# Set up zsh as default shell
RUN chsh -s $(which zsh)
{% endif %}

# Create non-root user (Claude Code refuses to run as root)
# UID/GID are auto-detected from host user to match file permissions on bind mounts
# Defaults: UID=501, GID=501 (macOS default)
ARG USERNAME=developer
ARG USER_UID=501
ARG USER_GID=501
ARG DOCKER_GID=999
RUN set -e; \
    # Create group if it doesn't exist
    if ! getent group $USER_GID >/dev/null 2>&1; then \
        groupadd --gid $USER_GID $USERNAME; \
    fi; \
    # Get the actual group name for this GID
    GROUP_NAME=$(getent group $USER_GID | cut -d: -f1); \
    # Create user if it doesn't exist
    if ! getent passwd $USER_UID >/dev/null 2>&1; then \
        useradd --uid $USER_UID --gid $USER_GID -m $USERNAME -s {% if 'zsh' in profile.system_packages %}/bin/zsh{% else %}/bin/bash{% endif %}; \
    else \
        # User exists, create home directory if needed
        mkdir -p /home/$USERNAME; \
    fi; \
    # Setup directories
    mkdir -p /home/$USERNAME/.local/bin \
    && mkdir -p /home/$USERNAME/.claude \
    && mkdir -p /home/$USERNAME/.happy \
    && mkdir -p /home/$USERNAME/.config/sops/age \
    && chown -R $USER_UID:$USER_GID /home/$USERNAME \
    && mkdir -p /Users \
    && chown $USER_UID:$USER_GID /Users

# Grant passwordless sudo access to developer user
RUN set -e; \
    ACTUAL_USERNAME=$(getent passwd $USER_UID | cut -d: -f1); \
    echo "$ACTUAL_USERNAME ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/$ACTUAL_USERNAME \
    && chmod 0440 /etc/sudoers.d/$ACTUAL_USERNAME

{% if profile.docker_cli %}
# Add user to docker group (GID matches docker.sock group on host)
# Use build arg DOCKER_GID to match host's docker socket group
RUN set -e; \
    ACTUAL_USERNAME=$(getent passwd $USER_UID | cut -d: -f1); \
    # Check if a group with DOCKER_GID already exists
    if getent group $DOCKER_GID > /dev/null 2>&1; then \
        # Group with that GID exists, get its name
        EXISTING_GROUP=$(getent group $DOCKER_GID | cut -d: -f1); \
        echo "Using existing group $EXISTING_GROUP (GID $DOCKER_GID) for docker socket access"; \
        usermod -aG $EXISTING_GROUP $ACTUAL_USERNAME; \
    else \
        # Create docker group with specified GID
        groupadd -g $DOCKER_GID docker; \
        usermod -aG docker $ACTUAL_USERNAME; \
    fi
{% endif %}

{% if 'zsh' in profile.system_packages %}
# Install oh-my-zsh for the user
RUN set -e; \
    cd /home/$USERNAME && \
    git clone --depth=1 https://github.com/ohmyzsh/ohmyzsh.git .oh-my-zsh && \
    cp .oh-my-zsh/templates/zshrc.zsh-template .zshrc && \
    chown -R $USER_UID:$USER_GID .oh-my-zsh .zshrc
{% endif %}

{% if 'tmux' in profile.system_packages %}
# Install oh-my-tmux for the user
RUN set -e; \
    cd /home/$USERNAME && \
    git clone --depth=1 https://github.com/gpakosz/.tmux.git && \
    ln -s -f .tmux/.tmux.conf .tmux.conf && \
    cp .tmux/.tmux.conf.local .tmux.conf.local && \
    chown -R $USER_UID:$USER_GID .tmux .tmux.conf .tmux.conf.local
{% endif %}

# Pre-configure Claude Code to skip onboarding prompts
RUN echo '{"hasCompletedOnboarding":true,"theme":"dark"}' > /home/$USERNAME/.claude.json \
    && chown $USER_UID:$USER_GID /home/$USERNAME/.claude.json

# Pre-configure Claude Code settings with broad permissions (container is isolated)
# Default model is set to Opus 4.5 for best code quality
RUN echo '{"permissions":{"allow":["Bash","Read","Write","Edit","Glob","Grep","Task","WebFetch","WebSearch","NotebookEdit"]},"defaultMode":"bypassPermissions","model":"claude-opus-4-5-20251101"}' > /home/$USERNAME/.claude/settings.json \
    && chown $USER_UID:$USER_GID /home/$USERNAME/.claude/settings.json


# Copy uv tools to user's path
RUN cp -r /root/.local/bin/* /home/$USERNAME/.local/bin/ \
    && chown -R $USER_UID:$USER_GID /home/$USERNAME/.local

# Create startup script that runs uv sync and then the command
RUN cat > /home/$USERNAME/.local/bin/devenv-start << 'SCRIPT'
#!/bin/sh
set -e

# Fix MCP plugin paths: Claude plugins store absolute host paths that don't exist in container
# Create symlink so /Users/<host-user>/.claude -> /home/developer/.claude
MARKETPLACES_JSON="/home/developer/.claude/plugins/known_marketplaces.json"
if [ -f "$MARKETPLACES_JSON" ]; then
    # Extract host username from installLocation path (e.g., /Users/ziefle/.claude/...)
    HOST_USER=$(grep -o '"/Users/[^/]*/' "$MARKETPLACES_JSON" 2>/dev/null | head -1 | sed 's|"/Users/||;s|/$||')
    if [ -n "$HOST_USER" ] && [ "$HOST_USER" != "developer" ]; then
        echo "Creating symlink for MCP plugin paths: /Users/$HOST_USER -> /home/developer"
        mkdir -p /Users 2>/dev/null || true
        ln -sfn /home/developer "/Users/$HOST_USER" 2>/dev/null || true
    fi
fi

{% if profile.mounts.ssh_keys %}
# Copy SSH keys and config from read-only mount to writable directory
if [ -d /home/developer/.ssh-host ]; then
    echo "Setting up SSH from host..."
    # Create writable .ssh directory and sockets subdirectory
    mkdir -p /home/developer/.ssh/sockets
    chmod 700 /home/developer/.ssh
    chmod 700 /home/developer/.ssh/sockets

    # Copy all SSH keys and known_hosts from host
    if [ -n "$(ls -A /home/developer/.ssh-host 2>/dev/null)" ]; then
        # Copy all files except config and sockets (we'll handle those specially)
        for file in /home/developer/.ssh-host/*; do
            filename=$(basename "$file")
            if [ "$filename" != "config" ] && [ "$filename" != "sockets" ]; then
                cp -r "$file" /home/developer/.ssh/
            fi
        done

        # Set proper permissions for keys
        chmod 600 /home/developer/.ssh/id_* 2>/dev/null || true
        chmod 644 /home/developer/.ssh/*.pub 2>/dev/null || true
        chmod 644 /home/developer/.ssh/known_hosts* 2>/dev/null || true
    fi

    # Handle SSH config: copy from host and strip problematic directives
    if [ -f /home/developer/.ssh-host/config ]; then
        # Copy host config but remove ControlPath/ControlMaster directives that point to non-writable locations
        # We'll add our own at the end to ensure they take precedence
        grep -v '^\s*ControlPath' /home/developer/.ssh-host/config | \
            grep -v '^\s*ControlMaster' | \
            grep -v '^\s*ControlPersist' > /home/developer/.ssh/config 2>/dev/null || true

        # Add our own ControlPath settings at the end (these take precedence over earlier Host * blocks)
        cat >> /home/developer/.ssh/config << 'SSHCONF'

# Container override: use writable socket directory
Host *
  ControlPath ~/.ssh/sockets/%r@%h-%p
  ControlMaster auto
  ControlPersist 10m
SSHCONF
        chmod 644 /home/developer/.ssh/config
    else
        # No host config - create default with ControlPath
        cat > /home/developer/.ssh/config << 'SSHCONF'
Host *
  ControlPath ~/.ssh/sockets/%r@%h-%p
  ControlMaster auto
  ControlPersist 10m
SSHCONF
        chmod 644 /home/developer/.ssh/config
    fi

    echo "  SSH setup complete (sockets in ~/.ssh/sockets/)"
fi
{% endif %}

# Copy useful files from host Claude config (if mounted at .claude-host)
# This preserves sandbox's permissive settings.json while getting auth, CLAUDE.md, etc.
if [ -d /home/developer/.claude-host ]; then
    # Copy credentials (auth token from 'claude login')
    if [ -f /home/developer/.claude-host/.credentials.json ]; then
        cp /home/developer/.claude-host/.credentials.json /home/developer/.claude/
    fi
    # Copy global CLAUDE.md if it exists
    if [ -f /home/developer/.claude-host/CLAUDE.md ]; then
        cp /home/developer/.claude-host/CLAUDE.md /home/developer/.claude/
    fi
    # Copy MCP plugins directory (serena, context7, etc. configs)
    if [ -d /home/developer/.claude-host/plugins ]; then
        echo "Copying MCP plugins from host..."
        cp -r /home/developer/.claude-host/plugins /home/developer/.claude/

        # Fix absolute paths in known_marketplaces.json (host paths don't exist in container)
        MARKETPLACES_JSON="/home/developer/.claude/plugins/known_marketplaces.json"
        if [ -f "$MARKETPLACES_JSON" ]; then
            echo "Fixing marketplace paths for container..."
            # Replace any /Users/<username>/.claude with /home/developer/.claude
            sed -i 's|/Users/[^/]*/\.claude|/home/developer/.claude|g' "$MARKETPLACES_JSON"
        fi

        # List copied MCP servers for debugging
        echo "MCP servers found:"
        find /home/developer/.claude/plugins -name ".mcp.json" -exec echo "  {}" \;
    fi
    # Copy projects directory (per-project CLAUDE.md files) if it exists
    if [ -d /home/developer/.claude-host/projects ]; then
        cp -r /home/developer/.claude-host/projects /home/developer/.claude/
    fi
    # Copy agents directory (custom agents) if it exists
    if [ -d /home/developer/.claude-host/agents ]; then
        echo "Copying custom agents from host..."
        cp -r /home/developer/.claude-host/agents /home/developer/.claude/
    fi
    # Copy skills directory (custom skills) if it exists
    if [ -d /home/developer/.claude-host/skills ]; then
        echo "Copying custom skills from host..."
        cp -r /home/developer/.claude-host/skills /home/developer/.claude/
    fi
    # Copy output-styles directory (custom output styles) if it exists
    if [ -d /home/developer/.claude-host/output-styles ]; then
        echo "Copying custom output styles from host..."
        cp -r /home/developer/.claude-host/output-styles /home/developer/.claude/
    fi
fi

# Copy Happy Coder config from host (if mounted at .happy-host)
if [ -d /home/developer/.happy-host ]; then
    echo "Copying Happy Coder config from host..."
    # Use cp -a to preserve permissions and copy all files including hidden ones
    if [ "$(ls -A /home/developer/.happy-host)" ]; then
        cp -a /home/developer/.happy-host/. /home/developer/.happy/
        # Ensure proper ownership for writable copy
        chmod -R u+w /home/developer/.happy
        echo "  Copied $(find /home/developer/.happy -type f | wc -l) files"
    else
        echo "  Warning: .happy-host is empty, nothing to copy"
    fi
fi

# Copy MCP servers from host's .claude.json to container's .claude.json
# This is needed because MCP servers are stored in ~/.claude.json, not ~/.claude/
if [ -f /home/developer/.claude.json-host ]; then
    echo "Merging MCP servers from host config..."
    # Find first workspace project for Serena auto-activation
    FIRST_PROJECT=""
    for dir in /workspace/*; do
        if [ -d "$dir" ]; then
            FIRST_PROJECT="$dir"
            break
        fi
    done
    export FIRST_PROJECT

    python3 << 'PYMCP' 2>/dev/null || true
import json
import os

host_config = '/home/developer/.claude.json-host'
container_config = '/home/developer/.claude.json'
first_project = os.environ.get('FIRST_PROJECT', '/workspace')

# Read host config
with open(host_config) as f:
    host_data = json.load(f)

# Read or create container config
try:
    with open(container_config) as f:
        container_data = json.load(f)
except:
    container_data = {"hasCompletedOnboarding": True, "theme": "dark"}

# Copy MCP servers from host (user-scoped, global)
if 'mcpServers' in host_data and host_data['mcpServers']:
    servers = host_data['mcpServers'].copy()

    # Fix Serena --project path: replace host path with container workspace path
    if 'serena' in servers:
        serena = servers['serena']
        if 'args' in serena:
            args = serena['args']
            # Find and replace --project argument
            for i, arg in enumerate(args):
                if arg == '--project' and i + 1 < len(args):
                    old_path = args[i + 1]
                    args[i + 1] = first_project
                    print(f"  Fixed Serena project: {old_path} -> {first_project}")
                    break

    container_data['mcpServers'] = servers
    print(f"  Copied {len(servers)} MCP servers: {list(servers.keys())}")

# Write merged config
with open(container_config, 'w') as f:
    json.dump(container_data, f, indent=2)
PYMCP
fi

# If SERENA_MCP_URL is set, override Serena config to use HTTP mode
if [ -n "$SERENA_MCP_URL" ]; then
    echo "Configuring Serena for HTTP mode..."
    SERENA_DIR="/home/developer/.claude/plugins/marketplaces/claude-plugins-official/external_plugins/serena"
    mkdir -p "$SERENA_DIR"
    cat > "$SERENA_DIR/.mcp.json" << SERENACFG
{
  "serena": {
    "type": "streamable-http",
    "url": "$SERENA_MCP_URL"
  }
}
SERENACFG
    echo "  Serena HTTP URL: $SERENA_MCP_URL"
    echo "  Config written to: $SERENA_DIR/.mcp.json"
fi

# Set up GPG agent socket forwarding from host (if GPG_AGENT_PORT is set)
if [ -n "$GPG_AGENT_PORT" ]; then
    # Create a writable GPG home directory
    GPG_HOME="/tmp/gnupg-runtime"
    mkdir -p "$GPG_HOME"
    chmod 700 "$GPG_HOME"

    # Copy gpg.conf but remove agent-program line and add no-autostart
    if [ -f /home/developer/.gnupg/gpg.conf ]; then
        grep -v '^agent-program' /home/developer/.gnupg/gpg.conf > "$GPG_HOME/gpg.conf" 2>/dev/null || true
    fi
    echo "no-autostart" >> "$GPG_HOME/gpg.conf"

    # Link the keyrings from the mounted directory
    ln -sf /home/developer/.gnupg/pubring.kbx "$GPG_HOME/" 2>/dev/null || true
    ln -sf /home/developer/.gnupg/trustdb.gpg "$GPG_HOME/" 2>/dev/null || true
    ln -sf /home/developer/.gnupg/private-keys-v1.d "$GPG_HOME/" 2>/dev/null || true

    # Remove any existing socket
    rm -f "$GPG_HOME/S.gpg-agent" 2>/dev/null || true

    # Start socat to bridge host GPG agent to local socket
    socat UNIX-LISTEN:"$GPG_HOME/S.gpg-agent",fork,mode=600 \
        TCP:host.docker.internal:"$GPG_AGENT_PORT" &

    # Set GNUPGHOME so GPG uses our directory with the forwarded socket
    export GNUPGHOME="$GPG_HOME"

    echo "GPG agent forwarding enabled on port $GPG_AGENT_PORT"
    sleep 0.5  # Give socat time to start
fi

# Find the first workspace directory with pyproject.toml
for dir in /workspace/*; do
    if [ -d "$dir" ] && [ -f "$dir/pyproject.toml" ]; then
        cd "$dir"

        # Check for stale .venv (symlinks to non-existent Python from host)
        if [ -d "$dir/.venv" ]; then
            VENV_PYTHON="$dir/.venv/bin/python"
            if [ -L "$VENV_PYTHON" ] && [ ! -e "$VENV_PYTHON" ]; then
                echo "Detected stale .venv (host Python not available), removing..."
                rm -rf "$dir/.venv"
            fi
        fi

        echo "Installing dependencies in $dir..."
        uv sync --quiet 2>/dev/null || true
        break
    fi
done

# If no command provided, start Claude in YOLO mode
if [ $# -eq 0 ]; then
    exec claude --permission-mode bypassPermissions
else
    exec "$@"
fi
SCRIPT
RUN chmod +x /home/$USERNAME/.local/bin/devenv-start

{% if 'gnupg' in profile.system_packages %}
# Create shell rc files with GPG forwarding support
RUN cat > /home/$USERNAME/.gpg_forward << 'GPGRC'
# Set up GPG agent forwarding if available
if [ -n "$GPG_AGENT_PORT" ] && [ -d "/tmp/gnupg-runtime" ]; then
    export GNUPGHOME="/tmp/gnupg-runtime"
fi
GPGRC

# Source GPG config in both bash and zsh
RUN echo '. ~/.gpg_forward' >> /home/$USERNAME/.bashrc \
    && echo '. ~/.gpg_forward' >> /home/$USERNAME/.zshrc \
    && chown $USER_UID:$USER_GID /home/$USERNAME/.gpg_forward /home/$USERNAME/.bashrc /home/$USERNAME/.zshrc
{% endif %}

{% if profile.network.mode == 'restricted' %}
# Create network restriction entrypoint (runs as root to configure iptables)
RUN cat > /usr/local/bin/network-entrypoint << 'NETSCRIPT'
#!/bin/sh
set -e

echo "Applying network restrictions..."

# Default policy: drop outgoing traffic
iptables -P OUTPUT DROP
ip6tables -P OUTPUT DROP 2>/dev/null || true

# Allow loopback (localhost)
iptables -A OUTPUT -o lo -j ACCEPT
ip6tables -A OUTPUT -o lo -j ACCEPT 2>/dev/null || true

# Allow established/related connections (for responses)
iptables -A OUTPUT -m state --state ESTABLISHED,RELATED -j ACCEPT
ip6tables -A OUTPUT -m state --state ESTABLISHED,RELATED -j ACCEPT 2>/dev/null || true

# Allow DNS (needed to resolve allowed domains)
iptables -A OUTPUT -p udp --dport 53 -j ACCEPT
iptables -A OUTPUT -p tcp --dport 53 -j ACCEPT
ip6tables -A OUTPUT -p udp --dport 53 -j ACCEPT 2>/dev/null || true
ip6tables -A OUTPUT -p tcp --dport 53 -j ACCEPT 2>/dev/null || true

# Resolve and allow each domain
ALLOWED_DOMAINS="{{ profile.network.effective_allowed_domains | join(' ') }}"
for domain in $ALLOWED_DOMAINS; do
    echo "  Allowing: $domain"
    # Resolve IPv4 addresses
    for ip in $(getent ahostsv4 "$domain" 2>/dev/null | awk '{print $1}' | sort -u); do
        iptables -A OUTPUT -d "$ip" -j ACCEPT 2>/dev/null || true
    done
    # Resolve IPv6 addresses
    for ip in $(getent ahostsv6 "$domain" 2>/dev/null | awk '{print $1}' | sort -u); do
        ip6tables -A OUTPUT -d "$ip" -j ACCEPT 2>/dev/null || true
    done
done

echo "Network restrictions applied."
echo "Allowed domains: $ALLOWED_DOMAINS"

# Switch to non-root user and run devenv-start
exec su - developer -c "devenv-start $*"
NETSCRIPT
RUN chmod +x /usr/local/bin/network-entrypoint
{% endif %}

# Switch to the user (using UID:GID to handle cases where user already exists)
USER $USER_UID:$USER_GID

# Create workspace directory
WORKDIR /workspace

# Set environment variables
ENV HOME=/home/developer
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV PATH="/home/developer/.local/bin:$PATH"
{% if 'zsh' in profile.system_packages %}
ENV SHELL=/bin/zsh
{% endif %}
{% if 'gnupg' in profile.system_packages %}
# Source GPG config for non-interactive bash (used by Claude)
ENV BASH_ENV=/home/developer/.gpg_forward
{% endif %}

# Health check - verify the shell is responsive
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD pgrep -x "claude" > /dev/null || pgrep -x "zsh" > /dev/null || pgrep -x "bash" > /dev/null || exit 1

{% if profile.network.mode == 'restricted' %}
# For restricted network mode, run as root first to apply iptables, then drop to user
USER root
ENTRYPOINT ["/usr/bin/tini", "--", "network-entrypoint"]
{% else %}
# Use startup script as entrypoint with tini for proper signal handling
ENTRYPOINT ["/usr/bin/tini", "--", "devenv-start"]
{% endif %}

# Default is to start Claude (handled by entrypoint when no args)
CMD []
