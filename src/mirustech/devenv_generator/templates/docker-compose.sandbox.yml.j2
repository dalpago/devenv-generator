# Generated by devenv-generator (sandbox mode)
# Profile: {{ profile.name }}
# Sandbox: {{ sandbox_name }}
#
# Usage:
#   # Run sandbox (with SOPS-encrypted .env):
#   SOPS_AGE_KEY_FILE=~/.config/chezmoi/key.txt sops exec-env .env 'docker-compose run --rm dev'
#
#   # Or with plain environment variable:
#   ANTHROPIC_AUTH_TOKEN=<token> docker-compose run --rm dev
#
#   # Inside container, projects are mounted at:
{% for mount in mounts %}
#   /workspace/{{ mount.name or mount.host_path.name }}{% if mount.mode == 'ro' %} (read-only){% elif mount.mode == 'cow' %} (copy-on-write){% endif %}

{% endfor %}

services:
  dev:
    build:
      context: .devcontainer
      dockerfile: Dockerfile
    volumes:
{% if use_host_claude_config %}
      # Host Claude configuration (CLAUDE.md, MCP servers, settings)
      - ~/.claude:/home/developer/.claude
{% else %}
      # Persistent Claude configuration (isolated from host)
      - claude-config:/home/developer/.claude
{% endif %}
{% for mount in mounts %}
{% if mount.mode == 'ro' %}
      # {{ mount.host_path.name }} (read-only)
      - {{ mount.host_path }}:{{ mount.container_path }}:ro
{% elif mount.mode == 'cow' %}
      # {{ mount.host_path.name }} (copy-on-write via tmpfs overlay)
      # Base layer (read-only)
      - {{ mount.host_path }}:{{ mount.container_path }}-base:ro
      # Upper layer for changes (tmpfs, discarded on container stop)
      - type: tmpfs
        target: {{ mount.container_path }}-upper
{% else %}
      # {{ mount.host_path.name }} (read-write)
      - {{ mount.host_path }}:{{ mount.container_path }}
{% endif %}
{% endfor %}
    environment:
      # Auth token passed from host
      - ANTHROPIC_AUTH_TOKEN
      # Skip permission prompts (sandbox is isolated)
      - CLAUDE_CODE_ACTION=bypassPermissions
{% for key, value in profile.environment.items() %}
      - {{ key }}={{ value }}
{% endfor %}
{% if has_cow_mounts %}
    # Set up overlay mounts for copy-on-write
    entrypoint: ["/bin/sh", "-c"]
    command:
      - |
        set -e
{% for mount in mounts %}
{% if mount.mode == 'cow' %}
        # Set up overlay for {{ mount.host_path.name }}
        mkdir -p {{ mount.container_path }}-upper/upper {{ mount.container_path }}-upper/work {{ mount.container_path }}
        mount -t overlay overlay -o lowerdir={{ mount.container_path }}-base,upperdir={{ mount.container_path }}-upper/upper,workdir={{ mount.container_path }}-upper/work {{ mount.container_path }}
{% endif %}
{% endfor %}
        exec /bin/zsh
{% else %}
    working_dir: /workspace/{{ default_workdir }}
{% endif %}
    stdin_open: true
    tty: true
{% if has_cow_mounts %}
    privileged: true  # Required for overlay mounts
{% endif %}

{% if not use_host_claude_config %}
volumes:
  claude-config:
    name: {{ sandbox_name }}-claude-config
{% endif %}
