# Generated by devenv-generator (sandbox mode)
# Profile: {{ profile.name }}
# Sandbox: {{ sandbox_name }}
#
# Usage:
#   # Run sandbox (with SOPS-encrypted .env):
#   SOPS_AGE_KEY_FILE=~/.config/chezmoi/key.txt sops exec-env .env 'docker-compose run --rm dev'
#
#   # Or with plain environment variable:
#   ANTHROPIC_AUTH_TOKEN=<token> docker-compose run --rm dev
#
#   # Inside container, projects are mounted at:
{% for mount in mounts %}
#   /workspace/{{ mount.name or mount.host_path.name }}{% if mount.mode == 'ro' %} (read-only){% elif mount.mode == 'cow' %} (copy-on-write){% endif %}

{% endfor %}

services:
  dev:
{% if image_spec %}
    image: {{ image_spec.full_name }}
{% endif %}
    build:
      context: .devcontainer
      dockerfile: Dockerfile
    volumes:
{% if use_host_claude_config %}
      # Host Claude config mounted read-only (for CLAUDE.md, MCP servers)
      # Settings are NOT inherited - sandbox uses permissive defaults
      - ~/.claude:/home/developer/.claude-host:ro
      # Claude user config (contains MCP server definitions) - mounted as -host for merging
      - ~/.claude.json:/home/developer/.claude.json-host:ro
{% endif %}
      # Git configuration from host
      - ~/.gitconfig:/home/developer/.gitconfig:ro
      # GPG keys for commit signing
      - ~/.gnupg:/home/developer/.gnupg
{% if profile.docker_cli %}
      # Docker socket for Docker-in-Docker
      - /var/run/docker.sock:/var/run/docker.sock
{% endif %}
{% if profile.mounts.happy_config %}
      # Happy Coder mobile client config (read-only, copied at runtime)
      - ~/.happy:/home/developer/.happy-host:ro
{% endif %}
{% for mount in mounts %}
{% if mount.mode == 'ro' %}
      # {{ mount.host_path.name }} (read-only)
      - {{ mount.host_path }}:{{ mount.container_path }}:ro
{% elif mount.mode == 'cow' %}
      # {{ mount.host_path.name }} (copy-on-write via tmpfs overlay)
      # Base layer (read-only)
      - {{ mount.host_path }}:{{ mount.container_path }}-base:ro
      # Upper layer for changes (tmpfs, discarded on container stop)
      - type: tmpfs
        target: {{ mount.container_path }}-upper
{% else %}
      # {{ mount.host_path.name }} (read-write)
      - {{ mount.host_path }}:{{ mount.container_path }}
{% endif %}
{% endfor %}
    environment:
      # Claude Code OAuth token (get via: claude setup-token)
      # This is the preferred auth method for containers on macOS
      - CLAUDE_CODE_OAUTH_TOKEN
      # Legacy: API key auth (still supported)
      - ANTHROPIC_AUTH_TOKEN
      # Skip permission prompts and warning dialog (sandbox is isolated)
      - IS_SANDBOX=1
      # Default to Opus model (overrides any settings.json changes)
      - ANTHROPIC_MODEL=opus
      # GPG agent forwarding (auto-started by devenv command)
      - GPG_AGENT_PORT=9876
      - GNUPGHOME=/tmp/gnupg-runtime
      # Serena MCP server URL (if running on host in HTTP mode)
      - SERENA_MCP_URL
      # Happy Coder server URL (for self-hosted Happy instances)
      - HAPPY_SERVER_URL
{% for key, value in profile.environment.items() %}
      - {{ key }}={{ value }}
{% endfor %}
{% if has_cow_mounts %}
    # Set up overlay mounts for copy-on-write
    entrypoint: ["/bin/sh", "-c"]
    command:
      - |
        set -e
{% for mount in mounts %}
{% if mount.mode == 'cow' %}
        # Set up overlay for {{ mount.host_path.name }}
        mkdir -p {{ mount.container_path }}-upper/upper {{ mount.container_path }}-upper/work {{ mount.container_path }}
        mount -t overlay overlay -o lowerdir={{ mount.container_path }}-base,upperdir={{ mount.container_path }}-upper/upper,workdir={{ mount.container_path }}-upper/work {{ mount.container_path }}
{% endif %}
{% endfor %}
        exec /bin/zsh
{% else %}
    working_dir: /workspace/{{ default_workdir }}
{% endif %}
    stdin_open: true
    tty: true
{% if profile.docker_cli %}
    # Grant access to docker socket (appears as root:root inside container on macOS)
    group_add:
      - "0"
{% endif %}
{% if has_cow_mounts %}
    privileged: true  # Required for overlay mounts
{% endif %}
