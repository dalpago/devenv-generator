{
  "name": "{{ project_name }}-dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
  "workspaceFolder": "/workspace",
  "mounts": [
{% if profile.mounts.claude_config == 'volume' %}
    "source={{ project_name }}-claude-config,target=/root/.claude,type=volume"
{% endif %}
  ],
  "postCreateCommand": "chmod +x .devcontainer/init-env.sh && .devcontainer/init-env.sh",
  "remoteEnv": {
{% for key, value in profile.environment.items() %}
{% if value.startswith('${') %}
    "{{ key }}": "${localEnv:{{ key }}}"{% if not loop.last %},{% endif %}

{% else %}
    "{{ key }}": "{{ value }}"{% if not loop.last %},{% endif %}

{% endif %}
{% endfor %}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff"
      ]
    }
  }
}
