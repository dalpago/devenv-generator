# Generated by devenv-generator
# Profile: {{ profile.name }}
#
# Usage:
#   # First time setup:
#   cp .env.example .env
#   # Add your ANTHROPIC_AUTH_TOKEN (get it via: claude setup-token)
#   sops encrypt --in-place .env
#
#   # Run container (decrypt .env first):
#   sops exec-env .env 'docker-compose run --rm dev'
#
#   # Inside container:
#   claude --dangerously-skip-permissions

services:
  dev:
{% if image_spec %}
    image: {{ image_spec.full_name }}
{% endif %}
    build:
      context: .devcontainer
      dockerfile: Dockerfile
      args:
        USER_UID: {{ user_uid }}
        USER_GID: {{ user_gid }}
{% if profile.docker_cli %}
        DOCKER_GID: {{ docker_gid }}
{% endif %}
    volumes:
      # Mount workspace (changes reflect on host)
      - .:/workspace
{% if profile.mounts.claude_config == 'volume' %}
      # Persistent Claude configuration
      - claude-config:/home/developer/.claude
{% elif profile.mounts.claude_config == 'bind' %}
      # Bind mount Claude config from host (shares auth with host)
      - ~/.claude:/home/developer/.claude
{% endif %}
{% if profile.mounts.gitconfig %}
      # Git configuration from host
      - ~/.gitconfig:/home/developer/.gitconfig:ro
{% endif %}
{% if profile.mounts.ssh_keys %}
      # SSH keys from host
      - ~/.ssh:/home/developer/.ssh:ro
{% endif %}
{% if profile.mounts.happy_config %}
      # Happy Coder mobile client config (read-only, copied at runtime)
      - ~/.happy:/home/developer/.happy-host:ro
{% endif %}
    environment:
      # Claude Code OAuth token (get via: claude setup-token)
      # This is the preferred auth method for containers on macOS
      - CLAUDE_CODE_OAUTH_TOKEN
      # Legacy: API key auth (still supported)
      - ANTHROPIC_AUTH_TOKEN
      # Skip permission prompts and warning dialog (container is isolated)
      - IS_SANDBOX=1
      # Default to Opus model (overrides any settings.json changes)
      - ANTHROPIC_MODEL=opus
      # Happy Coder server URL (for self-hosted Happy instances)
      - HAPPY_SERVER_URL
{% for key, value in profile.environment.items() %}
      - {{ key }}={{ value }}
{% endfor %}
    working_dir: /workspace
    stdin_open: true
    tty: true
{% if profile.ports.ports %}
    ports:
{% for port_config in profile.ports.ports %}
      # {{ port_config.description or 'Port ' ~ port_config.container }}
      - "127.0.0.1:{{ port_config.host_port }}:{{ port_config.container }}/{{ port_config.protocol }}"
{% endfor %}
{% endif %}
{% if profile.network.mode == 'none' %}
    # Completely disable networking
    network_mode: "none"
{% elif profile.network.mode == 'restricted' %}
    # Grant NET_ADMIN for iptables-based network restrictions
    cap_add:
      - NET_ADMIN
{% endif %}

{% if profile.mounts.claude_config == 'volume' %}
volumes:
  claude-config:
    name: {{ project_name }}-claude-config
{% endif %}
